{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Patchouli categories",
    "description": "File containing all information on Patchouli categories",
    "type": "object",
    "properties": {
        "categories": {
            "description": "The categories",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "displayName": {
                        "description": "The category display name",
                        "type": "string"
                    },
                    "code": {
                        "description": "The category abbreviation",
                        "type": "string"
                    },
                    "description": {
                        "description": "A description of the category",
                        "type": "string"
                    },
                    "series": {
                        "description": "The codes of the series in the category",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "additionalProperties": false,
                "required": ["displayName", "code", "description", "series"]
            }
        }
    },
    "additionalProperties": false,
    "required": ["categories"]
}
