{
	"name": "iris-studio",
	"version": "0.0.4",
	"description": "WYSIWYM editor for Iris documents",
	"author": "ksk",
	"private": true,
	"type": "module",
	"build": {
		"productName": "Iris Studio",
		"appId": "seki.pw.iris-studio",
		"electronLanguages": [
			"en-US"
		],
		"files": [
			"!src/",
			"!public/",
			"!*.config.js",
			"!pnpm-lock.yaml",
			"!shell.nix"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			]
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"category": "public.app-category.developer-tools"
		},
		"linux": {
			"target": [
				{
					"target": "appimage",
					"arch": [
						"x64"
					]
				}
			]
		}
	},
	"main": "./out/main/index.cjs",
	"scripts": {
		"dev": "electron-vite dev --watch",
		"devtools": "react-devtools",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"postinstall": "electron-builder install-app-deps",
		"dist": "patchouli-prebuild && electron-builder",
		"dist:all": "patchouli-prebuild && electron-builder -mwl",
		"tsc": "tsc --noEmit"
	},
	"devDependencies": {
		"@codemirror/commands": "^6.7.1",
		"@codemirror/language": "^6.10.3",
		"@codemirror/language-data": "^6.5.1",
		"@codemirror/state": "^6.4.1",
		"@codemirror/view": "^6.34.1",
		"@fontsource/atkinson-hyperlegible": "^5.1.0",
		"@fontsource/source-code-pro": "^5.1.0",
		"@fontsource/vollkorn": "^5.1.1",
		"@fontsource/vollkorn-sc": "^5.1.0",
		"@iconify-json/tabler": "^1.2.5",
		"@nytimes/react-prosemirror": "^0.6.1",
		"@reduxjs/toolkit": "^2.3.0",
		"@svgr/core": "^8.1.0",
		"@svgr/plugin-jsx": "^8.1.0",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.1",
		"@uiw/codemirror-extensions-color": "^4.23.5",
		"@uiw/codemirror-extensions-hyper-link": "^4.23.5",
		"@uiw/codemirror-theme-github": "^4.23.5",
		"@uiw/react-codemirror": "^4.23.5",
		"@vitejs/plugin-react": "^4.3.3",
		"autoprefixer": "^10.4.20",
		"chokidar": "^4.0.1",
		"electron": "33.0.1",
		"electron-builder": "^25.1.8",
		"electron-vite": "^2.3.0",
		"iris-common": "workspace:^",
		"iris-prosemirror": "workspace:^",
		"nightwind": "^1.1.13",
		"patchouli": "workspace:^",
		"postcss": "^8.4.47",
		"prosemirror-commands": "^1.6.1",
		"prosemirror-history": "^1.4.1",
		"prosemirror-model": "^1.23.0",
		"prosemirror-schema-list": "^1.4.1",
		"prosemirror-state": "^1.4.3",
		"prosemirror-tables": "^1.5.0",
		"prosemirror-view": "^1.34.3",
		"react": "^18.3.1",
		"react-arborist": "^3.4.0",
		"react-aria-components": "1.2.1",
		"react-devtools": "^6.0.1",
		"react-dom": "^18.3.1",
		"react-redux": "^9.1.2",
		"react-resizable-panels": "^2.1.4",
		"redux-remember": "^5.1.0",
		"tailwindcss": "^3.4.14",
		"ts-node": "^10.9.2",
		"unplugin-icons": "^0.19.3",
		"use-resize-observer": "^9.1.0",
		"vite": "^5.4.9",
		"vite-plugin-svgr": "^4.2.0"
	}
}
