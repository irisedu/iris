{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Patchouli article frontmatter",
    "description": "Patchouli article frontmatter",
    "type": "object",
    "properties": {
        "type": {
            "description": "The type of article",
            "enum": ["normal", "definition", "stub"]
        },
        "title": {
            "description": "The title of the article",
            "type": "string"
        },
        "authors": {
            "description": "IDs of the authors of the article",
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            }
        },
        "tags": {
            "description": "Tags for the article",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "cite": {
            "description": "List of citation keys to include in references even if not present in the article",
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "additionalProperties": false,
    "required": ["title"]
}
