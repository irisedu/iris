{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Patchouli series metadata",
    "description": "Metadata for Patchouli series and courses",
    "type": "object",
    "properties": {
        "type": {
            "description": "The type of series",
            "enum": ["series", "course", "misc"]
        },
        "code": {
            "description": "The series code",
            "type": "string"
        },
        "title": {
            "description": "The title of the series",
            "type": "string"
        },
        "description": {
            "description": "A description of the series",
            "type": "string"
        },
        "authors": {
            "description": "IDs of the authors of the series",
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            }
        },
        "tags": {
            "description": "Tags for the series",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "prerequisites": {
            "description": "Codes of the prerequisites of this series",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "corequisites": {
            "description": "Codes of the corequisites of this series",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "chapters": {
            "description": "Series chapters, listed in order",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "top_level": {
                        "description": "Whether the articles in the chapter should be listed at the top level of the series",
                        "type": "boolean"
                    },
                    "title": {
                        "description": "Title of the chapter",
                        "type": "string"
                    },
                    "articles": {
                        "description": "Paths to articles in order, excluding extension",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "additionalProperties": false,
                "required": ["articles"]
            }
        }
    },
    "additionalProperties": false,
    "required": ["type", "code", "title", "description", "authors", "chapters"]
}
